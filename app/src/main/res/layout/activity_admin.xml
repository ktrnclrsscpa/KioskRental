<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADMIN DASHBOARD"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnGenerate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GENERATE NEW 6-CHAR PIN"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

    <TextView
        android:id="@+id/tvGeneratedPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PIN will appear here"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="30dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/etExtendPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter PIN to extend"
        android:inputType="textCapCharacters"/>

    <Button
        android:id="@+id/btnExtend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ADD 30 MINUTES"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"/>

</LinearLayout>